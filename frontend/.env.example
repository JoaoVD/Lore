# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co  # URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key              # Anon key (segura para expor no browser)

# ── Stripe ───────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...                    # Chave pública do Stripe
STRIPE_SECRET_KEY=sk_test_...                                     # Chave secreta do Stripe (apenas server-side)
STRIPE_WEBHOOK_SECRET=whsec_...                                   # Secret do webhook
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key          # Service role key (apenas server-side)

# Price IDs públicos — usados no billing/page.tsx
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...                    # Lore Pro R$180/mês
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_...                     # Lore Pro R$1800/ano
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS_MONTHLY=price_...               # Lore Business R$290/mês
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS_ANNUAL=price_...                # Lore Business R$2900/ano

# Price IDs server-side — usados no webhook /api/stripe/webhook (NÃO prefixe com NEXT_PUBLIC_)
STRIPE_PRICE_ID_PRO=price_...                                     # Lore Pro R$180/mês
STRIPE_PRICE_ID_BUSINESS=price_...                                # Lore Business R$290/mês

# ── Backend API ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000                         # URL base da API FastAPI (sem /api/v1)
