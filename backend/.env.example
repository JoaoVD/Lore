# ── Project ──────────────────────────────────────────────
PROJECT_NAME="Lore"
VERSION="0.1.0"

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co        # URL do projeto Supabase
SUPABASE_SERVICE_KEY=your_supabase_service_role_key         # Service role key (bypassa o RLS)
SUPABASE_ANON_KEY=your_supabase_anon_key                    # Anon key (uso opcional no backend)
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# ── Qdrant ────────────────────────────────────────────────
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.qdrant.io  # URL do Qdrant Cloud
QDRANT_API_KEY=your_qdrant_api_key                          # API key do Qdrant

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...                                  # Chave da OpenAI Platform
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                               # Chave secreta do Stripe (apenas server-side)
STRIPE_WEBHOOK_SECRET=whsec_...                             # Secret do webhook (stripe listen --print-secret)
# Price IDs — crie no Stripe Dashboard > Products (com trial_period_days=14)
STRIPE_PRICE_ID_PRO=price_...                               # Lore Pro R$180/mês
STRIPE_PRICE_ID_BUSINESS=price_...                          # Lore Business R$290/mês

# ── Auth (JWT) ───────────────────────────────────────────
SECRET_KEY=                                                 # Segredo JWT — gere com: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440                            # 24h

# ── URLs ─────────────────────────────────────────────────
FRONTEND_URL=http://uselore.com.br
